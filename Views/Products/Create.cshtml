@model Kiemtragiuaki.Models.Product
@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới - FutureTech";
}

<div class="container my-5 max-width-800">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-sm btn-glass px-3 py-2 text-decoration-none">
            <i class="bi bi-arrow-left"></i> Quay Lại Danh Sách
        </a>
    </div>

    <div class="card-3d p-4 p-md-5" style="background: rgba(255,255,255,0.85);">
        <h2 class="fw-bold font-heading text-slate-800 mb-4">Thêm Sản Phẩm Mới</h2>

        <form asp-action="Create" method="post" class="row g-3">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Name -->
            <div class="col-md-8">
                <label asp-for="Name" class="form-label fw-bold text-secondary">Tên Sản Phẩm <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control bg-light border-slate-200 py-2" placeholder="Nhập tên sản phẩm..." required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <!-- SKU -->
            <div class="col-md-4">
                <label asp-for="Sku" class="form-label fw-bold text-secondary">Mã SKU <span class="text-danger">*</span></label>
                <input asp-for="Sku" class="form-control bg-light border-slate-200 py-2" placeholder="Ví dụ: LAP-ASUS-01" required />
                <span asp-validation-for="Sku" class="text-danger small"></span>
            </div>

            <!-- Slug -->
            <div class="col-md-6">
                <label asp-for="Slug" class="form-label fw-bold text-secondary">Đường Dẫn Slug (Tự động nếu để trống)</label>
                <input asp-for="Slug" class="form-control bg-light border-slate-200 py-2" placeholder="asus-rog-strix-g16" />
                <span asp-validation-for="Slug" class="text-danger small"></span>
            </div>

            <!-- Image Link -->
            <div class="col-md-6">
                <label asp-for="MainImage" class="form-label fw-bold text-secondary">Đường Dẫn Hình Ảnh (URL)</label>
                <input asp-for="MainImage" class="form-control bg-light border-slate-200 py-2" placeholder="https://images.unsplash.com/..." />
                <span asp-validation-for="MainImage" class="text-danger small"></span>
            </div>

            <!-- Category -->
            <div class="col-md-6">
                <label asp-for="CategoryId" class="form-label fw-bold text-secondary">Danh Mục <span class="text-danger">*</span></label>
                <select asp-for="CategoryId" class="form-select bg-light border-slate-200 py-2" asp-items="ViewBag.CategoryId" required>
                    <option value="">-- Chọn Danh Mục --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            <!-- Brand -->
            <div class="col-md-6">
                <label asp-for="BrandId" class="form-label fw-bold text-secondary">Thương Hiệu <span class="text-danger">*</span></label>
                <select asp-for="BrandId" class="form-select bg-light border-slate-200 py-2" asp-items="ViewBag.BrandId" required>
                    <option value="">-- Chọn Thương Hiệu --</option>
                </select>
                <span asp-validation-for="BrandId" class="text-danger small"></span>
            </div>

            <!-- Price -->
            <div class="col-md-4">
                <label asp-for="Price" class="form-label fw-bold text-secondary">Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                <input asp-for="Price" type="number" step="1000" class="form-control bg-light border-slate-200 py-2" placeholder="Giá niêm yết..." required />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>

            <!-- Cost Price -->
            <div class="col-md-4">
                <label asp-for="CostPrice" class="form-label fw-bold text-secondary">Giá Vốn (VNĐ)</label>
                <input asp-for="CostPrice" type="number" step="1000" class="form-control bg-light border-slate-200 py-2" placeholder="Giá nhập kho..." />
                <span asp-validation-for="CostPrice" class="text-danger small"></span>
            </div>

            <!-- Discount Percent -->
            <div class="col-md-4">
                <label asp-for="DiscountPercent" class="form-label fw-bold text-secondary">Phần Trăm Giảm Giá (%)</label>
                <input asp-for="DiscountPercent" type="number" min="0" max="100" class="form-control bg-light border-slate-200 py-2" placeholder="0 - 100..." />
                <span asp-validation-for="DiscountPercent" class="text-danger small"></span>
            </div>

            <!-- Quantity -->
            <div class="col-md-4">
                <label asp-for="Quantity" class="form-label fw-bold text-secondary">Số Lượng Tồn Kho <span class="text-danger">*</span></label>
                <input asp-for="Quantity" type="number" class="form-control bg-light border-slate-200 py-2" placeholder="0..." required />
                <span asp-validation-for="Quantity" class="text-danger small"></span>
            </div>

            <!-- Status -->
            <div class="col-md-4">
                <label asp-for="Status" class="form-label fw-bold text-secondary">Trạng Thái</label>
                <select asp-for="Status" class="form-select bg-light border-slate-200 py-2">
                    <option value="active">Kích Hoạt (Active)</option>
                    <option value="draft">Bản Nháp (Draft)</option>
                    <option value="inactive">Khóa (Inactive)</option>
                </select>
                <span asp-validation-for="Status" class="text-danger small"></span>
            </div>

            <!-- Featured checkbox -->
            <div class="col-md-4 d-flex align-items-center mt-md-4 pt-md-2">
                <div class="form-check">
                    <input asp-for="Featured" type="checkbox" class="form-check-input" id="FeaturedCheck" />
                    <label class="form-check-label fw-bold text-secondary" for="FeaturedCheck">Sản Phẩm Nổi Bật</label>
                </div>
            </div>

            <!-- Short Description -->
            <div class="col-12">
                <label asp-for="ShortDescription" class="form-label fw-bold text-secondary">Mô Tả Ngắn</label>
                <textarea asp-for="ShortDescription" rows="2" class="form-control bg-light border-slate-200" placeholder="Viết mô tả ngắn gọn về sản phẩm..."></textarea>
                <span asp-validation-for="ShortDescription" class="text-danger small"></span>
            </div>

            <!-- Full Description -->
            <div class="col-12">
                <label asp-for="FullDescription" class="form-label fw-bold text-secondary">Mô Tả Chi Tiết</label>
                <textarea asp-for="FullDescription" rows="4" class="form-control bg-light border-slate-200" placeholder="Mô tả chi tiết cấu hình, ưu nhược điểm..."></textarea>
                <span asp-validation-for="FullDescription" class="text-danger small"></span>
            </div>

            <!-- Submit buttons -->
            <div class="col-12 d-flex gap-3 justify-content-end mt-4">
                <a asp-action="Index" class="btn btn-glass px-4 py-2">Hủy Bỏ</a>
                <button type="submit" class="btn btn-neon-purple px-5 py-2">
                    <i class="bi bi-check-lg me-1"></i> Lưu Sản Nhân
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
