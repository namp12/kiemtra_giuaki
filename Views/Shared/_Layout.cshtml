<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FutureTech 3D Computer Store</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Kiemtragiuaki.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light navbar-custom py-3 fixed-top">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-cpu-fill fs-3" style="color: var(--neon-cyan);"></i>
                    <span>FUTURE<span style="color: var(--neon-purple);">TECH</span></span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto gap-2 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link active d-flex align-items-center gap-1" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Trang Chủ
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1" href="/#catalog">
                                <i class="bi bi-grid-3x3-gap"></i> Sản Phẩm
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1" href="/#metrics">
                                <i class="bi bi-bar-chart"></i> Thống Kê
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link d-flex align-items-center gap-1" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-folder-fill"></i> Quản Lý
                            </a>
                        </li>
                        
                        <li class="nav-item ms-lg-3 d-flex align-items-center gap-2">
                            <!-- Seeder -->
                            <form asp-controller="Home" asp-action="SeedDemoData" method="post" class="d-inline m-0">
                                <button type="submit" class="btn btn-sm btn-neon-purple px-3 py-2">
                                    <i class="bi bi-database-fill-gear"></i> Nạp Dữ Liệu Mẫu
                                </button>
                            </form>
                            
                            <!-- Light/Dark Mode Switcher -->
                            <button id="themeToggle" class="btn btn-glass px-3 py-2 border-0" title="Chuyển chế độ sáng/tối">
                                <i id="themeIcon" class="bi bi-moon-stars-fill"></i>
                            </button>

                            <!-- Shopping Cart Button -->
                            <button class="btn btn-glass px-3 py-2 position-relative border-0" data-bs-toggle="offcanvas" data-bs-target="#cartOffcanvas" title="Xem giỏ hàng">
                                <i class="bi bi-cart3"></i>
                                <span id="cartCountBadge" class="cart-badge d-none">0</span>
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container" style="margin-top: 100px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <!-- Offcanvas Shopping Cart Drawer -->
    <div class="offcanvas offcanvas-end cart-offcanvas" tabindex="-1" id="cartOffcanvas" aria-labelledby="cartOffcanvasLabel">
        <div class="offcanvas-header border-bottom border-secondary border-opacity-10 py-4 px-4">
            <h5 class="offcanvas-title fw-bold font-heading" id="cartOffcanvasLabel">
                <i class="bi bi-cart3 me-1"></i> Giỏ Hàng Của Bạn
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close" id="cartCloseBtn"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column px-4">
            <!-- Cart Items List -->
            <div id="cartItemsList" class="flex-grow-1 overflow-y-auto pr-1">
                <!-- Dynamically loaded from site.js -->
            </div>
            
            <!-- Cart Footer Summary -->
            <div class="border-top border-secondary border-opacity-10 pt-4 mt-auto">
                <div class="d-flex justify-content-between mb-3 align-items-center">
                    <span class="text-muted fw-bold">Tổng tiền thanh toán:</span>
                    <span id="cartTotalSum" class="fs-4 fw-extrabold text-cyan font-heading">0đ</span>
                </div>
                <button class="btn btn-lg btn-neon-purple w-100 py-3 fw-bold mb-2" onclick="checkout()">
                    <i class="bi bi-credit-card-2-front-fill me-2"></i> Tiến Hành Thanh Toán
                </button>
            </div>
        </div>
    </div>

    <footer class="footer-custom mt-auto">
        <div class="container text-center">
            <div class="row align-items-center justify-content-between g-4">
                <div class="col-md-4 text-md-start">
                    <h5 class="fw-bold mb-2 font-heading" style="background: linear-gradient(135deg, var(--neon-cyan), var(--neon-purple)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                        FUTURETECH STORE
                    </h5>
                    <p class="text-muted small mb-0">Trải nghiệm mua sắm linh kiện máy tính 3D đỉnh cao của tương lai.</p>
                </div>
                <div class="col-md-4">
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="text-muted fs-4 hover-cyan"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-muted fs-4 hover-cyan"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="text-muted fs-4 hover-cyan"><i class="bi bi-github"></i></a>
                    </div>
                </div>
                <div class="col-md-4 text-md-end small text-muted">
                    &copy; 2026 - FutureTech. Đã đăng ký bản quyền.
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
